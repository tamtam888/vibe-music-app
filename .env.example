# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL — found in Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=

# Anon/public key — found in Supabase Dashboard → Settings → API
VITE_SUPABASE_ANON_KEY=

# ── Spotify ───────────────────────────────────────────────────────────────────
# Client ID — found in https://developer.spotify.com/dashboard
# Register these Redirect URIs in the Spotify app settings:
#   Production: https://vibe-music-app-phi.vercel.app
#   Local dev:  http://127.0.0.1:8080
VITE_SPOTIFY_CLIENT_ID=

# ── AI Generation (optional) ──────────────────────────────────────────────────
# Uncomment and set to enable AI track generation.
# Supported values: replicate | suno | supabase
# VITE_GENERATION_PROVIDER=
